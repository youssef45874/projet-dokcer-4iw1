FROM node:20-alpine

WORKDIR /app

COPY --chown=node:node package*.json ./
RUN if [ -f package-lock.json ]; then npm ci --omit=dev --no-audit --no-fund; else npm install --omit=dev --no-audit --no-fund; fi && npm cache clean --force

COPY --chown=node:node . .

EXPOSE 8080
USER node

CMD ["npm", "run", "dev"]
